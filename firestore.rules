rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserId(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function ownsExisting(fieldName) {
      return signedIn() && resource.data[fieldName] == request.auth.uid;
    }

    function ownsIncoming(fieldName) {
      return signedIn() && request.resource.data[fieldName] == request.auth.uid;
    }

    match /profiles/{userId} {
      allow create, read, update, delete: if ownsUserId(userId);
    }

    match /users/{userId} {
      allow create, read, update, delete: if ownsUserId(userId);
    }

    match /events/{eventId} {
      allow read: if resource.data.status == "active" || ownsExisting("hostId") || ownsExisting("host_id");
      allow create: if ownsIncoming("hostId") || ownsIncoming("host_id");
      allow update, delete: if ownsExisting("hostId") || ownsExisting("host_id");
    }

    match /tickets/{ticketId} {
      allow create: if ownsIncoming("userId") || ownsIncoming("user_id");
      allow read, update, delete: if ownsExisting("userId") || ownsExisting("user_id") || ownsExisting("hostId") || ownsExisting("host_id");
    }

    match /payments/{paymentId} {
      allow create: if ownsIncoming("userId") || ownsIncoming("user_id");
      allow read: if ownsExisting("userId") || ownsExisting("user_id");
      allow update, delete: if false;
    }

    match /conversations/{conversationId} {
      allow create: if signedIn()
        && (request.resource.data.participant1 == request.auth.uid
          || request.resource.data.participant2 == request.auth.uid);
      allow read, update: if signedIn()
        && (resource.data.participant1 == request.auth.uid
          || resource.data.participant2 == request.auth.uid);
      allow delete: if false;
    }

    match /messages/{messageId} {
      allow create: if ownsIncoming("senderId") || ownsIncoming("sender_id");
      allow read: if signedIn()
        && (resource.data.senderId == request.auth.uid
          || resource.data.sender_id == request.auth.uid
          || resource.data.receiverId == request.auth.uid
          || resource.data.receiver_id == request.auth.uid);
      allow update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow create, read, update, delete: if ownsExisting("userId") || ownsExisting("user_id") || ownsIncoming("userId") || ownsIncoming("user_id");
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
