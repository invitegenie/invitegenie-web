# Supabase Configuration
# Found in Project Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Development-only Super Admin 2FA placeholder.
# Do not use this as production SMS/MFA security.
VITE_DEV_SUPER_ADMIN_OTP=123456

# Google Gemini AI Configuration
# Obtain from https://aistudio.google.com/
VITE_GEMINI_API_KEY=your-gemini-api-key

# Optional Invite Genie image generation endpoint.
# Should accept POST { prompt, event, width, height } and return { imageUrl } or { dataUrl }.
VITE_INVITE_IMAGE_GENERATION_ENDPOINT=https://your-image-generation-endpoint.example.com/generate

# App Configuration
VITE_APP_ENV=development
